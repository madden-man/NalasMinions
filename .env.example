# MongoDB connection for the Electron app.
# Copy this file to `.env` and paste your MongoDB Atlas SRV connection string.
# The app always uses the "tommy-data" database (set in electron/mongo.cjs);
# you do not need to put a database name in the URI.
#
# Get this from Atlas: Cluster → Connect → Drivers → copy the connection string,
# then replace <username>/<password> with a database user's credentials.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Push notifications for the "Bump" button, delivered via ntfy.sh.
# Install the ntfy app (iOS/Android) and subscribe to your topic to get a push
# whenever someone taps Bump.
#   NTFY_TOPIC   the secret topic to publish to (required — the app errors without it)
#   NTFY_SERVER  the ntfy server base URL (optional, defaults to https://ntfy.sh)
NTFY_TOPIC=Ali_Tommy_Bump_Buddies
# NTFY_SERVER=https://ntfy.sh
